{
  "id": "io.github.astrovm.AdventureMods.Devel",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": ["org.freedesktop.Sdk.Extension.rust-stable"],
  "command": "adventure-mods",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--device=dri",
    "--socket=wayland",
    "--filesystem=~/.steam/debian-installation",
    "--filesystem=~/.steam/steam",
    "--filesystem=~/.local/share/Steam",
    "--filesystem=~/.var/app/com.valvesoftware.Steam/.local/share/Steam",
    "--filesystem=/mnt",
    "--filesystem=/media",
    "--filesystem=/run/media",
    "--talk-name=org.freedesktop.Flatpak"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/share/pkgconfig",
    "/share/aclocal",
    "/man",
    "/share/man",
    "/share/gtk-doc",
    "/share/vala",
    "*.la",
    "*.a"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "RUST_BACKTRACE": "1",
      "RUSTFLAGS": "-D warnings",
      "CARGO_REGISTRIES_CRATES_IO_PROTOCOL": "sparse"
    }
  },
  "modules": [
    "flatpak/7zip.json",
    "flatpak/hdiffpatch.json",
    {
      "name": "adventure-mods",
      "buildsystem": "meson",
      "config-opts": ["-Dprofile=development"],
      "build-options": {
        "env": {
          "CARGO_HOME": "/run/build/adventure-mods/cargo"
        }
      },
      "sources": [
        {
          "type": "dir",
          "path": "..",
          "skip": [".flatpak-builder", "appimage-build", "build", "target"]
        },
        "cargo-sources.json"
      ]
    }
  ]
}
