{
  "id": "io.github.astrovm.AdventureMods.Devel",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": ["org.freedesktop.Sdk.Extension.rust-stable"],
  "command": "adventure-mods",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--device=dri",
    "--socket=wayland",
    "--filesystem=~/.steam/debian-installation",
    "--filesystem=~/.steam/steam",
    "--filesystem=~/.local/share/Steam",
    "--filesystem=~/.var/app/com.valvesoftware.Steam/.local/share/Steam",
    "--filesystem=/mnt",
    "--filesystem=/media",
    "--filesystem=/run/media",
    "--talk-name=org.freedesktop.Flatpak"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/share/pkgconfig",
    "/share/aclocal",
    "/man",
    "/share/man",
    "/share/gtk-doc",
    "/share/vala",
    "*.la",
    "*.a"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "RUST_BACKTRACE": "1",
      "RUSTFLAGS": "-D warnings",
      "CARGO_REGISTRIES_CRATES_IO_PROTOCOL": "sparse"
    }
  },
  "modules": [
    {
      "name": "7zip",
      "buildsystem": "simple",
      "build-commands": ["tar xf 7zip.tar.xz", "install -Dm755 7zz /app/bin/7zz"],
      "sources": [
        {
          "type": "file",
          "url": "https://github.com/ip7z/7zip/releases/download/26.00/7z2600-linux-x64.tar.xz",
          "dest-filename": "7zip.tar.xz",
          "sha256": "c74dc4a48492cde43f5fec10d53fb2a66f520e4a62a69d630c44cb22c477edc6"
        }
      ]
    },
    {
      "name": "hdiffpatch",
      "buildsystem": "simple",
      "build-commands": ["install -Dm755 hpatchz /app/bin/hpatchz"],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/sisong/HDiffPatch/releases/download/v4.12.2/hdiffpatch_v4.12.2_bin_linux64.zip",
          "sha256": "432886341e6099adeb5223427454e9bc0b565f81edfbe2e3387f804611c07e4a"
        }
      ]
    },
    {
      "name": "adventure-mods",
      "buildsystem": "meson",
      "config-opts": ["-Dprofile=development"],
      "build-options": {
        "env": {
          "CARGO_HOME": "/run/build/adventure-mods/cargo"
        }
      },
      "sources": [
        {
          "type": "dir",
          "path": "..",
          "skip": [".flatpak-builder", "appimage-build", "build", "target"]
        },
        "cargo-sources.json"
      ]
    }
  ]
}
