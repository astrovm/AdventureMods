<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="AdventureModsWindow" parent="AdwApplicationWindow">
    <property name="title" translatable="yes">Adventure Mods</property>
    <property name="default-width">872</property>
    <property name="default-height">666</property>
    <property name="content">
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar" id="header_bar">
            <property name="centering-policy">strict</property>
            <child type="end">
              <object class="GtkButton" id="refresh_button">
                <property name="tooltip-text" translatable="yes">Refresh detected Steam libraries</property>
                <style>
                  <class name="flat"/>
                </style>
                <child>
                  <object class="GtkImage">
                    <property name="icon-name">view-refresh-symbolic</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <property name="content">
          <object class="AdwNavigationView" id="navigation_view">
            <child>
              <object class="AdwNavigationPage">
                <property name="tag">welcome</property>
                <property name="title" translatable="yes">Adventure Mods</property>
                <property name="child">
                  <object class="AdventureModsWelcomePage" id="welcome_page"/>
                </property>
              </object>
            </child>
          </object>
        </property>
      </object>
    </property>
  </template>
</interface>
