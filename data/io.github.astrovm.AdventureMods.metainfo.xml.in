<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.astrovm.AdventureMods</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>Adventure Mods</name>
  <summary>Install Sonic Adventure mods</summary>
  <description>
    <p>
      Install mods for Sonic Adventure DX and Sonic Adventure 2.
      Detects your Steam installations, downloads a curated collection of community
      mods, and configures everything automatically — mod managers, runtimes,
      resolution, and load order — so you can jump straight into the definitive
      versions of both games.
    </p>
    <ul>
      <li>Automatic detection of SADX and SA2 across all Steam library folders</li>
      <li>29 curated SADX mods and 13 SA2 mods, individually selectable</li>
      <li>Presets for quick setup: DX Enhanced and Dreamcast Restoration</li>
      <li>Installs mod managers, mods, and dependencies in one go</li>
      <li>Configures native resolution, window mode, and optimal settings</li>
    </ul>
  </description>
  <url type="homepage">https://github.com/astrovm/AdventureMods</url>
  <url type="bugtracker">https://github.com/astrovm/AdventureMods/issues</url>
  <url type="vcs-browser">https://github.com/astrovm/AdventureMods</url>
  <developer id="io.github.astrovm">
    <name>astrovm</name>
  </developer>
  <launchable type="desktop-id">io.github.astrovm.AdventureMods.desktop</launchable>
  <content_rating type="oars-1.1" />
  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/astrovm/AdventureMods/main/data/screenshots/welcome.png</image>
      <caption>Welcome screen with automatic game detection</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/astrovm/AdventureMods/main/data/screenshots/mod-selection.png</image>
      <caption>Mod selection with preview and preset configurations</caption>
    </screenshot>
  </screenshots>
  <branding>
    <color type="primary" scheme_preference="light">#62a0ea</color>
    <color type="primary" scheme_preference="dark">#1a5fb4</color>
  </branding>
  <releases>
    <release version="0.1.0" date="2026-03-15">
      <description>
        <p>First release with full mod setup support for Sonic Adventure DX and Sonic Adventure 2. Includes automatic Steam detection, curated mod presets, native mod manager installation, and .NET runtime configuration via protontricks.</p>
      </description>
    </release>
  </releases>
</component>
