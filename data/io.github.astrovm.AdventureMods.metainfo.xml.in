<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>@APP_ID_RAW@</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>Adventure Mods</name>
  <summary>Set up Sonic Adventure mods</summary>
  <description>
    <p>
      The easiest way to mod Sonic Adventure DX and Sonic Adventure 2 on Linux.
      It finds your Steam games, downloads community mods, and handles all the setup
      for you. Mod managers, runtimes, resolution, load order, everything is ready
      to go so you can play the best versions of both games right away.
    </p>
    <ul>
      <li>Finds SADX and SA2 across all your Steam library folders</li>
      <li>29 SADX mods and 13 SA2 mods to pick from</li>
      <li>Quick presets: DX Enhanced and Dreamcast Restoration</li>
      <li>Gets mod managers, mods, and dependencies all at once</li>
      <li>Sets up native resolution, window mode, and optimal settings</li>
    </ul>
  </description>
  <url type="homepage">https://github.com/astrovm/AdventureMods</url>
  <url type="bugtracker">https://github.com/astrovm/AdventureMods/issues</url>
  <url type="vcs-browser">https://github.com/astrovm/AdventureMods</url>
  <developer id="io.github.astrovm">
    <name>astrovm</name>
  </developer>
  <launchable type="desktop-id">@APP_ID_RAW@.desktop</launchable>
  <content_rating type="oars-1.1" />
  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/astrovm/AdventureMods/main/data/screenshots/welcome.png</image>
      <caption>Welcome screen with automatic game detection</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/astrovm/AdventureMods/main/data/screenshots/mod-selection.png</image>
      <caption>Mod selection with preview and preset configurations</caption>
    </screenshot>
  </screenshots>
  <branding>
    <color type="primary" scheme_preference="light">#62a0ea</color>
    <color type="primary" scheme_preference="dark">#1a5fb4</color>
  </branding>
  <releases>
    <release version="0.2.2" date="2026-04-07">
      <description>
        <p>Fix AppImage archive extraction by bundling 7z binary directly instead of using wrapper script with hardcoded paths.</p>
      </description>
    </release>
    <release version="0.2.1" date="2026-04-07">
      <description>
        <p>CI release workflow fix: releases now publish correctly with AppImage assets.</p>
      </description>
    </release>
    <release version="0.2.0" date="2026-04-07">
      <description>
        <p>Direct Proton integration replacing protontricks, multi-library Steam detection, overhauled welcome page with cover images, SA2 mod presets, and numerous bug fixes for game card visibility and download handling.</p>
      </description>
    </release>
    <release version="0.1.0" date="2026-03-15">
      <description>
        <p>First release. Full mod setup for Sonic Adventure DX and Sonic Adventure 2 with Steam detection, mod presets, mod manager installation, and .NET runtime setup through protontricks.</p>
      </description>
    </release>
  </releases>
</component>
