<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>@APP_ID_RAW@</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>Adventure Mods</name>
  <summary>Set up Sonic Adventure mods</summary>
  <description>
    <p>
      The easiest way to mod Sonic Adventure DX and Sonic Adventure 2 on Linux.
      Finds your Steam installs, downloads community mods, and handles mod
      managers, runtimes, resolution, load order, and language settings so you
      can play right away.
    </p>
    <ul>
      <li>Detects SADX and SA2 across all Steam library folders</li>
      <li>29 SADX mods and 12 SA2 mods</li>
      <li>SADX presets: DX Enhanced and Dreamcast Restoration</li>
      <li>Installs mod managers, mods, and dependencies in one step</li>
      <li>Configures native resolution, window mode, and optimal settings</li>
      <li>Lets you choose subtitle and voice language during setup</li>
    </ul>
  </description>
  <url type="homepage">https://github.com/astrovm/AdventureMods</url>
  <url type="bugtracker">https://github.com/astrovm/AdventureMods/issues</url>
  <url type="vcs-browser">https://github.com/astrovm/AdventureMods</url>
  <developer id="io.github.astrovm">
    <name>astrovm</name>
  </developer>
  <launchable type="desktop-id">@APP_ID_RAW@.desktop</launchable>
  <content_rating type="oars-1.1" />
  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/astrovm/AdventureMods/main/data/screenshots/welcome.png</image>
      <caption>Welcome screen with automatic game detection</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/astrovm/AdventureMods/main/data/screenshots/mod-selection.png</image>
      <caption>Mod selection with preview and preset configurations</caption>
    </screenshot>
  </screenshots>
  <branding>
    <color type="primary" scheme_preference="light">#62a0ea</color>
    <color type="primary" scheme_preference="dark">#1a5fb4</color>
  </branding>
  <releases>
    <release version="0.3.5" date="2026-04-13">
      <description>
        <ul>
          <li>Paths in the UI and CLI now abbreviate the home directory as ~</li>
        </ul>
      </description>
    </release>
    <release version="0.3.4" date="2026-04-11">
      <description>
        <p>CLI setup now prompts for language and detects physical resolution.</p>
        <ul>
          <li>Interactive CLI setup prompts for subtitle and voice language like the GUI does</li>
          <li>Resolution detection uses physical pixel dimensions accounting for fractional scaling</li>
        </ul>
      </description>
    </release>
    <release version="0.3.3" date="2026-04-10">
      <description>
        <p>Faster, more reliable mod setup.</p>
        <ul>
          <li>Downloads and installs selected mods concurrently during setup</li>
          <li>Resolves the latest GameBanana downloads at install time</li>
          <li>Downloads SA2 Render Fix directly from its GitHub releases page</li>
        </ul>
      </description>
    </release>
    <release version="0.3.2" date="2026-04-10">
      <description>
        <p>Improved progress reporting in both the GUI and CLI.</p>
        <ul>
          <li>GUI progress bars now show meaningful status labels during all download steps</li>
          <li>Per-mod byte-level download progress shown in both GUI and CLI</li>
          <li>CLI displays live MB counter for convert and mod manager download steps</li>
        </ul>
      </description>
    </release>
    <release version="0.3.1" date="2026-04-10">
      <description>
        <p>Removed status messages shown after game detection.</p>
      </description>
    </release>
    <release version="0.3.0" date="2026-04-08">
      <description>
        <p>Added a full command-line workflow for setup and detection, plus manual language selection during setup.</p>
        <ul>
          <li>Added detect command to show supported game installs and inaccessible Steam libraries</li>
          <li>Added list-mods command to show presets and recommended mods by game</li>
          <li>Added setup command for headless installation and config generation</li>
          <li>Added subtitle and voice language selection for SADX and SA2 setup</li>
          <li>Saved language selections per game so rerunning setup reuses the last choice</li>
        </ul>
      </description>
    </release>
    <release version="0.2.4" date="2026-04-08">
      <description>
        <p>Improved setup reliability and Steam integration.</p>
        <ul>
          <li>Replaced protontricks-based setup with direct Proton integration</li>
          <li>Expanded Steam library detection</li>
          <li>Improved the welcome page and setup flow</li>
          <li>Fixed packaged archive extraction</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2026-03-15">
      <description>
        <p>First release.</p>
        <ul>
          <li>Full mod setup for Sonic Adventure DX and Sonic Adventure 2</li>
          <li>Steam install detection</li>
          <li>Mod preset support</li>
          <li>Mod manager installation</li>
          <li>.NET runtime setup through protontricks</li>
        </ul>
      </description>
    </release>
  </releases>
</component>
