<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>@APP_ID_RAW@</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>Adventure Mods</name>
  <summary>Set up Sonic Adventure mods</summary>
  <description>
    <p>
      The easiest way to mod Sonic Adventure DX and Sonic Adventure 2 on Linux.
      Finds your Steam installs, downloads community mods, and handles mod
      managers, runtimes, resolution, load order, and language settings so you
      can play right away.
    </p>
    <ul>
      <li>Detects SADX and SA2 across all Steam library folders</li>
      <li>29 SADX mods and 12 SA2 mods</li>
      <li>SADX presets: DX Enhanced and Dreamcast Restoration</li>
      <li>Installs mod managers, mods, and dependencies in one step</li>
      <li>Configures native resolution, window mode, and optimal settings</li>
      <li>Lets you choose subtitle and voice language during setup</li>
    </ul>
  </description>
  <url type="homepage">https://github.com/astrovm/AdventureMods</url>
  <url type="bugtracker">https://github.com/astrovm/AdventureMods/issues</url>
  <url type="vcs-browser">https://github.com/astrovm/AdventureMods</url>
  <developer id="io.github.astrovm">
    <name>astrovm</name>
  </developer>
  <launchable type="desktop-id">@APP_ID_RAW@.desktop</launchable>
  <content_rating type="oars-1.1" />
  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/astrovm/AdventureMods/main/data/screenshots/welcome.png</image>
      <caption>Welcome screen with automatic game detection</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/astrovm/AdventureMods/main/data/screenshots/mod-selection.png</image>
      <caption>Mod selection with preview and preset configurations</caption>
    </screenshot>
  </screenshots>
  <branding>
    <color type="primary" scheme_preference="light">#62a0ea</color>
    <color type="primary" scheme_preference="dark">#1a5fb4</color>
  </branding>
  <releases>
    <release version="0.3.0" date="2026-04-08">
      <description>
        <p>Added CLI commands for game detection, mod listing, and headless setup, plus startup fixes so CLI downloads initialize TLS correctly.</p>
      </description>
    </release>
    <release version="0.2.4" date="2026-04-08">
      <description>
        <p>Direct Proton integration replaced protontricks, Steam library detection was expanded, the welcome and setup flow were improved, and packaged archive extraction was corrected.</p>
      </description>
    </release>
    <release version="0.1.0" date="2026-03-15">
      <description>
        <p>First release. Full mod setup for Sonic Adventure DX and Sonic Adventure 2 with Steam detection, mod presets, mod manager installation, and .NET runtime setup through protontricks.</p>
      </description>
    </release>
  </releases>
</component>
