<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="adventure-mods">
  <schema id="@APP_ID_RAW@" path="@APP_PATH_RAW@">
    <key name="window-width" type="i">
      <default>872</default>
      <summary>Default window width</summary>
    </key>
    <key name="window-height" type="i">
      <default>666</default>
      <summary>Default window height</summary>
    </key>
    <key name="window-maximized" type="b">
      <default>false</default>
      <summary>Whether the window is maximized</summary>
    </key>
    <key name="extra-library-paths" type="as">
      <default>[]</default>
      <summary>Extra Steam library paths granted through portals</summary>
    </key>
    <key name="sadx-subtitle-language" type="s">
      <default>'japanese'</default>
      <summary>SADX subtitle language</summary>
    </key>
    <key name="sadx-voice-language" type="s">
      <default>'english'</default>
      <summary>SADX voice language</summary>
    </key>
    <key name="sa2-subtitle-language" type="s">
      <default>'english'</default>
      <summary>SA2 subtitle language</summary>
    </key>
    <key name="sa2-voice-language" type="s">
      <default>'english'</default>
      <summary>SA2 voice language</summary>
    </key>
  </schema>
</schemalist>
